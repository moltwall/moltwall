# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Upstash Redis
UPSTASH_REDIS_URL=https://your-redis.upstash.io
UPSTASH_REDIS_TOKEN=your-upstash-token

# AgentWall
# Used to sign and verify internal tokens
AGENTWALL_SECRET=your-32-char-secret-here

# Next.js public URL (used by SDK and dashboard)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Privy (for Try Demo auth)
NEXT_PUBLIC_PRIVY_APP_ID=your-privy-app-id

# Maintenance mode (set to "true" to show maintenance page at "/")
NEXT_PUBLIC_SHOW_MP=false